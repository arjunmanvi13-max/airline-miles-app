{
  "manifest_version": 3,
  "name": "Vantara",
  "version": "0.1.0",
  "description": "Analyze award flights on Seats.aero before transferring points.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vantara"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://vantaratravel.net/*",
    "https://seats.aero/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://seats.aero/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}