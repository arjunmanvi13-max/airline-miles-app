{
  "manifest_version": 3,
  "name": "Vantara",
  "version": "0.1.5",
  "description": "Analyze award flights on supported award search websites before transferring points.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vantara"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://vantaratravel.net/*",
    "https://seats.aero/*",
    "https://www.pointsyeah.com/*",
    "https://pointsyeah.com/*",
    "https://roame.travel/*",
    "https://www.roame.travel/*",
    "https://awardtool.com/*",
    "https://www.awardtool.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://seats.aero/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.pointsyeah.com/*",
        "https://pointsyeah.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://roame.travel/*",
        "https://www.roame.travel/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },

    {
  "matches": [
    "https://point.me/*",
    "https://www.point.me/*"
  ],
  "js": ["content.js"],
  "run_at": "document_idle"
    },
    {
  "matches": [
    "https://awardtool.com/*",
    "https://www.awardtool.com/*"
  ],
  "js": ["content.js"],
  "run_at": "document_idle"
}
  ]
}